# NocoDB Configuration
NOCO_URL=https://your-nocodb-app.nocodb.com
NOCO_TOKEN=your-nocodb-api-token-here

# Server
PORT=3000

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-domain.com,https://*.facebook.com

# Optional: Facebook Messenger Webhook secret
FB_WEBHOOK_SECRET=your-fb-webhook-secret

# Optional: Analytics
ANALYTICS_ENDPOINT=https://analytics.example.com/track
